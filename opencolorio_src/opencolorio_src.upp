description "OpenColorIO 2.5.2 core source package";

noblitz
NOWARNINGS

options
	-IE:/apps/github/upp_imaging/opencolorio_src/OpenColorIO,
	-IE:/apps/github/upp_imaging/opencolorio_src,
	-IE:/apps/github/upp_imaging/opencolorio_src/upstream/src,
	-IE:/apps/github/upp_imaging/pystring_src,
	-I.,
	-Iupstream/src/OpenColorIO,
	-I../pystring,
	-I../pystring_src,
	-Iext/sampleicc/src/include,
	-Iext/xxHash/src/include;

uses
	expat,
	yaml_cpp,
	pystring,
	minizip_ng,
	imath,
	zlib;

library(WIN32) bcrypt;

