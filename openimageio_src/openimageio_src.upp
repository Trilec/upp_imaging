description "Strict upstream OpenImageIO 3.1.15.0 main source package";

noblitz;

options
	-I.,
	-Iupstream,
	-Iupstream/libOpenImageIO,
	-Iupstream/OpenImageIO,
	-Iupstream/libtexture,
	-I../openimageio_util_src/upstream,
	-DOpenImageIO_EXPORTS,
	-DOIIO_STATIC_DEFINE=1,
	-DWIN32_LEAN_AND_MEAN,
	-DNOMINMAX,
	-DNOGDI,
	-DVC_EXTRALEAN,
	-DOIIO_INTERNAL=1,
	-DOIIO_OPENEXR_CORE_DEFAULT=1;

uses
	openimageio_util_src,
	openexr,
	imath,
	zlib,
	libtiff,
	libjpeg_turbo,
	opencolorio,
	fmt,
	robinmap;

library(WIN32) psapi;

file
	OIIO.h,
	README.md,
	buildopts.h,
	upstream/OpenImageIO/oiioversion.h,
	upstream/OpenImageIO/export.h,
	upstream/OpenImageIO/Imath.h,
	upstream/OpenImageIO/imageio.h,
	upstream/OpenImageIO/imagebuf.h,
	upstream/OpenImageIO/imagebufalgo.h,
	upstream/OpenImageIO/imagebufalgo_util.h,
	upstream/OpenImageIO/imagecache.h,
	upstream/OpenImageIO/color.h,
	upstream/OpenImageIO/half.h,
	upstream/OpenImageIO/deepdata.h,
	upstream/OpenImageIO/image_span.h,
	upstream/OpenImageIO/image_view.h,
	upstream/OpenImageIO/texture.h,
	upstream/OpenImageIO/tiffutils.h,
	upstream/OpenImageIO/tiff.h,
	upstream/OpenImageIO/imageio_pvt.h,
	upstream/libOpenImageIO/imageio_pvt.h,
	upstream/OpenImageIO/imagecache_pvt.h,
	upstream/OpenImageIO/imagecache_memory_pvt.h,
	upstream/OpenImageIO/imagecache_memory_print.h,
	upstream/OpenImageIO/texture_pvt.h,
	upstream/OpenImageIO/imagebufalgo_demosaic_prv.h,
	upstream/OpenImageIO/exif.h,
	upstream/OpenImageIO/detail/pugixml/pugiconfig.hpp,
	upstream/OpenImageIO/detail/pugixml/pugixml.hpp,
	upstream/OpenImageIO/kissfft.hh,
	upstream/OpenColorIO/OpenColorIO.h,
	upstream/Imath/half.h,
	upstream/Imath/ImathBox.h,
	upstream/Imath/ImathColor.h,
	upstream/Imath/ImathMatrix.h,
	upstream/Imath/ImathVec.h,
	upstream/detail/pugixml/pugiconfig.hpp,
	upstream/detail/pugixml/pugixml.hpp,
	upstream/detail/pugixml/pugixml.cpp,
	upstream/libOpenImageIO/imagebufalgo.cpp,
	upstream/libOpenImageIO/imagebufalgo_pixelmath.cpp,
	upstream/libOpenImageIO/imagebufalgo_channels.cpp,
	upstream/libOpenImageIO/imagebufalgo_compare.cpp,
	upstream/libOpenImageIO/imagebufalgo_copy.cpp,
	upstream/libOpenImageIO/imagebufalgo_deep.cpp,
	upstream/libOpenImageIO/imagebufalgo_draw.cpp,
	upstream/libOpenImageIO/imagebufalgo_addsub.cpp,
	upstream/libOpenImageIO/imagebufalgo_muldiv.cpp,
	upstream/libOpenImageIO/imagebufalgo_mad.cpp,
	upstream/libOpenImageIO/imagebufalgo_minmaxchan.cpp,
	upstream/libOpenImageIO/imagebufalgo_orient.cpp,
	upstream/libOpenImageIO/imagebufalgo_xform.cpp,
	upstream/libOpenImageIO/imagebufalgo_demosaic.cpp,
	upstream/libOpenImageIO/imagebufalgo_yee.cpp,
	upstream/libOpenImageIO/imagebufalgo_flip.cpp,
	upstream/libOpenImageIO/deepdata.cpp,
	upstream/libOpenImageIO/exif.cpp,
	upstream/libOpenImageIO/exif-canon.cpp,
	upstream/libOpenImageIO/formatspec.cpp,
	upstream/libOpenImageIO/icc.cpp,
	upstream/libOpenImageIO/imagebuf.cpp,
	upstream/libOpenImageIO/imageinput.cpp,
	upstream/libOpenImageIO/imageio.cpp,
	upstream/libOpenImageIO/imageioplugin.cpp,
	upstream/libOpenImageIO/imageoutput.cpp,
	upstream/libOpenImageIO/iptc.cpp,
	upstream/libOpenImageIO/xmp.cpp,
	upstream/libOpenImageIO/color_ocio.cpp,
	upstream/libOpenImageIO/maketexture.cpp,
	upstream/libOpenImageIO/bluenoise.cpp,
	upstream/libOpenImageIO/printinfo.cpp,
	upstream/libOpenImageIO/oiio_gpu.cpp,
	upstream/libtexture/texturesys.cpp,
	upstream/libtexture/texture3d.cpp,
	upstream/libtexture/environment.cpp,
	upstream/libtexture/texoptions.cpp,
	upstream/libtexture/imagecache.cpp;
