description "OpenImageIO PNG plugin registration package";

uses
	openimageio_src,
	libpng,
	zlib;

options
	-I../openimageio_headers,
	-I../openimageio_src,
	-I../openimageio_src/upstream/libOpenImageIO,
	-I../libpng,
	-I../libpng/upstream,
	-I../libtiff_src/upstream/libtiff,
	-Iupstream,
	-Iupstream/png.imageio,
	-DOIIO_STATIC_DEFINE=1;

file
	upstream/png.imageio/pnginput.cpp,
	upstream/png.imageio/pngoutput.cpp,
	upstream/png.imageio/png_pvt.h,
	RegisterPNG.h,
	RegisterPNG.cpp,
	README.md;
